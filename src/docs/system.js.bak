/**
 * @swagger
 * /health:
 *   get:
 *     tags:
 *       - System
 *     summary: Get system health
 *     description: Checks the health and status of the API
 *     security: []
 *     responses:
 *       200:
 *         description: System is healthy
 *         content:
 *           application/json:
 *             schema:
 *               type: object
 *               properties:
 *                 status:
 *                   type: string
 *                   example: ok
 *                 uptime:
 *                   type: string
 *                   example: 24h
 */

/**
 * @swagger
 * /version:
 *   get:
 *     tags:
 *       - System
 *     summary: Get API version
 *     description: Returns the current deployed version of the API
 *     security: []
 *     responses:
 *       200:
 *         description: Version information retrieved
 *         content:
 *           application/json:
 *             schema:
 *               type: object
 *               properties:
 *                 version:
 *                   type: string
 *                   example: v1.0.0
 *                 releaseDate:
 *                   type: string
 *                   example: 2025-11-04
 */
